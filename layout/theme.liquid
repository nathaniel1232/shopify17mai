<!DOCTYPE html>
<html lang="nb" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {{ page_title }}{% unless page_title contains shop.name %} – {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ 'splash-theme.css' | asset_url | stylesheet_tag }}

  {% style %}
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-secondary: {{ settings.color_secondary }};
      --color-accent: {{ settings.color_accent }};
      --color-bg: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-text-light: {{ settings.color_text_light }};
      --font-heading: 'Playfair Display', Georgia, serif;
      --font-body: 'Inter', system-ui, -apple-system, sans-serif;
    }
  {% endstyle %}

  <script>document.documentElement.classList.replace('no-js', 'js');</script>
</head>
<body class="template-{{ template.name }}{% if settings.campaign_mode == '17mai' %} campaign-17mai{% elsif settings.campaign_mode == 'summer' %} campaign-summer{% endif %}">

  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'splash-theme.js' | asset_url | script_tag }}
</body>
</html>
