<section class="collection-main">
  <div class="container">
    <div class="collection-header">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p class="collection-description">{{ collection.description }}</p>
      {% endif %}
      <p class="collection-count">{{ collection.products_count }} produkter</p>
    </div>

    <div class="collection-toolbar">
      <div class="collection-sort">
        <label for="sort-by">Sorter etter:</label>
        <select id="sort-by" onchange="window.location.href = this.value;">
          {% for option in collection.sort_options %}
            <option
              value="{{ option.url }}"
              {% if collection.sort_by == option.value %}selected{% endif %}
            >
              {{ option.name }}
            </option>
          {% endfor %}
        </select>
      </div>
    </div>

    {% if collection.products.size > 0 %}
      <div class="product-grid product-grid--4">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        {% paginate collection.products by 12 %}
          <nav class="pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="pagination-btn">← Forrige</a>
            {% endif %}

            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}" class="pagination-btn">{{ part.title }}</a>
              {% else %}
                <span class="pagination-btn pagination-btn--active">{{ part.title }}</span>
              {% endif %}
            {% endfor %}

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="pagination-btn">Neste →</a>
            {% endif %}
          </nav>
        {% endpaginate %}
      {% endif %}
    {% else %}
      <div class="collection-empty">
        <p>Ingen produkter funnet 😢</p>
        <a href="/collections/all" class="btn btn--primary">Se alle produkter</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Kolleksjonsside",
  "tag": "section",
  "class": "collection-section"
}
{% endschema %}
