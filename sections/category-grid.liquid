<section class="category-grid">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>

    <div class="categories">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__image">
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="600"
                height="400"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="category-card__overlay">
            <h3 class="category-card__title">{{ block.settings.title }}</h3>
            <span class="category-card__cta">Utforsk →</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kategorier",
  "tag": "section",
  "class": "category-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Utforsk kategoriene"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategori",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bilde"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "Kategori"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lenke"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kategorier"
    }
  ]
}
{% endschema %}
