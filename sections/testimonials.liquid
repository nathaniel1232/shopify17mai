<section class="testimonials">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>

    <div class="testimonial-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-stars">
            {% for i in (1..block.settings.stars) %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent)" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% endfor %}
          </div>
          <p class="testimonial-text">"{{ block.settings.text }}"</p>
          <p class="testimonial-author">— {{ block.settings.author }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Anmeldelser",
  "tag": "section",
  "class": "testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Hva kundene sier"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Anmeldelse",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Stjerner",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Anmeldelsestekst",
          "default": "Beste vannpistolen ever!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Navn",
          "default": "Fornøyd kunde"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Anmeldelser"
    }
  ]
}
{% endschema %}
