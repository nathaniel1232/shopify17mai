<section class="hero-banner" style="{% if section.settings.image %}background-image: url('{{ section.settings.image | image_url: width: 1920 }}');{% endif %}">
  <div class="hero-overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="hero-content container">
    <div class="hero-badge">
      {% if settings.campaign_mode == '17mai' %}
        <span class="badge badge--flag">17. mai-spesial</span>
      {% elsif settings.campaign_mode == 'summer' %}
        <span class="badge badge--summer">Sommertilbud</span>
      {% endif %}
    </div>
    <h1 class="hero-heading">{{ section.settings.heading }}</h1>
    <p class="hero-subheading">{{ section.settings.subheading }}</p>
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--large">
        {{ section.settings.button_label }}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bakgrunnsbilde"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Opplev vannlek på et nytt nivå"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Undertekst",
      "default": "Norges kuleste vannpistoler for tidenes beste feiring"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knappetekst",
      "default": "Se alle vannpistoler"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Knappelenke"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay gjennomsiktighet",
      "min": 0,
      "max": 90,
      "step": 10,
      "default": 30,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
