<section class="usp-banner">
  <div class="container">
    <div class="usp-grid">
      {% for block in section.blocks %}
        <div class="usp-item" {{ block.shopify_attributes }}>
          <div class="usp-icon">
            {% case block.settings.icon %}
              {% when 'truck' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% when 'shield' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {% when 'clock' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {% when 'star' %}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% endcase %}
          </div>
          <div class="usp-text">
            <strong>{{ block.settings.title }}</strong>
            <span>{{ block.settings.text }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "USP Banner",
  "tag": "section",
  "class": "usp-section",
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ikon",
          "options": [
            { "value": "truck", "label": "Frakt" },
            { "value": "shield", "label": "Sikkerhet" },
            { "value": "clock", "label": "Klokke" },
            { "value": "star", "label": "Stjerne" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "Gratis frakt"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Over 499 kr"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP Banner",
      "blocks": [
        { "type": "usp", "settings": { "icon": "truck", "title": "Gratis frakt", "text": "Over 499 kr" } },
        { "type": "usp", "settings": { "icon": "shield", "title": "Trygg handel", "text": "Sikker betaling" } },
        { "type": "usp", "settings": { "icon": "clock", "title": "Rask levering", "text": "1-3 virkedager" } },
        { "type": "usp", "settings": { "icon": "star", "title": "Topp kvalitet", "text": "Garantert moro" } }
      ]
    }
  ]
}
{% endschema %}
